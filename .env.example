# =============================================================
# Dropin — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env or .env.local with real secrets.
# =============================================================

# ── Database ──────────────────────────────────────────────────
# Postgres connection string (Neon, Supabase, Railway, etc.)
# Local dev: use Neon free tier or a local postgres instance
# Vercel: set this in Project Settings → Environment Variables
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ── XRPL ──────────────────────────────────────────────────────
# Testnet WebSocket endpoint (switch to mainnet URL for production)
XRPL_NODE_URL="wss://s.altnet.rippletest.net:51233"

# Platform wallet — used server-side to sign Credentials (Track B)
# Generate once with xrpl.js Wallet.generate() or from Crossmark testnet
NEXT_PUBLIC_PLATFORM_WALLET="r..."
PLATFORM_WALLET_SEED="s..."

# ── RLUSD ─────────────────────────────────────────────────────
# Testnet RLUSD issuer — find the full address from testnet.xrpl.org
# (different from mainnet issuer rMxCKbEDwqr76QuheSUMdEGf4B9xJ8m5De)
NEXT_PUBLIC_RLUSD_ISSUER="rQhWct2..."
NEXT_PUBLIC_RLUSD_CURRENCY="524C555344000000000000000000000000000000"
